venv/
.venv/
env/

# ── IDE配置 ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── 系统文件 ─────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Streamlit缓存 ────────────────────────────────────────────
.streamlit/

# ── 临时文件 ─────────────────────────────────────────────────
*.tmp
*.log
